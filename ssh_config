# Host IPs live in ~/.ssh/config.local (not in this repo)
# Format:
#   Host dl-content-host
#       HostName <ip>
#   Host dl-coder
#       HostName <ip>
Include ~/.ssh/config.local

Host dl-content-host
    User daniel.langkilde
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes

Host dl-coder
    User daniel
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes

Host *
    AddKeysToAgent yes
    IdentityFile ~/.ssh/id_ed25519
